# LintGenius Configuration (Environment Variables)
# Copy this file to .env and customize as needed.

# Maximum cyclomatic complexity allowed (default: 10)
LINTGENIUS_MAX_COMPLEXITY=10

# Maximum function length in lines (default: 50)
LINTGENIUS_MAX_FUNCTION_LENGTH=50

# Naming convention: snake_case | camelCase (default: snake_case)
LINTGENIUS_NAMING_CONVENTION=snake_case

# Enable docstring checks (default: true)
LINTGENIUS_CHECK_DOCSTRINGS=true

# Enable security checks (default: true)
LINTGENIUS_CHECK_SECURITY=true

# Output format: rich | json (default: rich)
LINTGENIUS_OUTPUT_FORMAT=rich
